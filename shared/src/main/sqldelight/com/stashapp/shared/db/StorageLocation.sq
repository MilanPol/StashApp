CREATE TABLE storage_location (
    id TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL,
    icon TEXT NOT NULL DEFAULT ''
);

selectAll:
SELECT * FROM storage_location ORDER BY name;

insert:
INSERT OR REPLACE INTO storage_location(id, name, icon) VALUES (?, ?, ?);

update:
UPDATE storage_location SET name = ?, icon = ? WHERE id = ?;

deleteById:
DELETE FROM storage_location WHERE id = ?;
